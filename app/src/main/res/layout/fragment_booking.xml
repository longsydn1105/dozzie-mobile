<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Xác nhận và Chọn phòng"
        android:textColor="@color/dozzie_navy"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Dùng NestedScrollView để cuộn toàn bộ nội dung bên dưới Title -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTitle">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 1. BẢNG THÔNG TIN XÁC NHẬN (Cái Card cũ của ông) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="@color/dozzie_navy"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <include layout="@layout/item_booking_info" android:id="@+id/rowUser"/>
                    <include layout="@layout/item_booking_info" android:id="@+id/rowEmail"/>
                    <include layout="@layout/item_booking_info" android:id="@+id/rowPhone"/>
                    <include android:id="@+id/rowGender" layout="@layout/item_booking_info" />

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#33FFFFFF" android:layout_marginVertical="12dp"/>
                    <include layout="@layout/item_booking_info" android:id="@+id/rowDate"/>
                    <include layout="@layout/item_booking_info" android:id="@+id/rowTimeIn"/>
                    <include layout="@layout/item_booking_info" android:id="@+id/rowTimeOut"/>
                    <include layout="@layout/item_booking_info" android:id="@+id/rowPackage"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 2. DANH SÁCH PHÒNG (Chèn đoạn ông hỏi vào đây) -->

            <!-- Container cho Khu Nam -->
            <LinearLayout
                android:id="@+id/layoutMaleRooms"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Khu vực Nam (Tầng 3)"
                    android:padding="16dp"
                    android:textStyle="bold"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvMaleRooms"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>
            </LinearLayout>

            <!-- Container cho Khu Nữ -->
            <LinearLayout
                android:id="@+id/layoutFemaleRooms"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Khu vực Nữ (Tầng 2)"
                    android:padding="16dp"
                    android:textStyle="bold"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvFemaleRooms"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>
            </LinearLayout>
            <!-- Khoảng đệm dưới cùng cho đẹp -->
            <View android:layout_width="match_parent" android:layout_height="32dp"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <Button
        android:id="@+id/btnConfirmBooking"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_margin="16dp"
        android:text="Xác nhận đặt phòng"
        android:textAllCaps="false"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="@color/dozzie_blue"
        android:enabled="false"
        android:alpha="0.5"
        app:cornerRadius="12dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>