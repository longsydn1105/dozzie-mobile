<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="110dp"
    android:layout_height="160dp"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    app:strokeWidth="1dp"
    app:strokeColor="#E0E0E0">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Phòng trên (Lẻ: 01, 03...) -->
        <FrameLayout
            android:id="@+id/layoutTopRoom"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="8dp">
            <TextView android:id="@+id/tvTopId" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textStyle="bold" android:textSize="12sp"/>
            <TextView android:id="@+id/tvTopStatus" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:layout_gravity="bottom" android:textSize="9sp" android:textColor="@color/status_danger"/>
        </FrameLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0"/>

        <!-- Phòng dưới (Chẵn: 02, 04...) -->
        <FrameLayout
            android:id="@+id/layoutBottomRoom"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="8dp">
            <TextView android:id="@+id/tvBottomId" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:layout_gravity="end|bottom" android:textStyle="bold" android:textSize="12sp"/>
            <TextView android:id="@+id/tvBottomStatus" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textSize="9sp" android:textColor="@color/status_danger"/>
        </FrameLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>