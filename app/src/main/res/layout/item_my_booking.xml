<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:id="@+id/tvRoomLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kén 03 - Tầng 3"
                android:textColor="@color/dozzie_navy"
                android:textStyle="bold"
                android:textSize="16sp" />
            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:background="#FEE2E2"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:text="ĐÃ HỦY"
                android:textColor="@color/dozzie_danger"
                android:textSize="10sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <TextView
            android:id="@+id/tvPackageName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nghi giữa trưa (1h)"
            android:textSize="12sp"
            android:alpha="0.7" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="#F9FAFB"
            android:padding="12dp"
            android:orientation="horizontal">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_height="wrap_content">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CHECK-IN" android:textSize="10sp" />
                <TextView android:id="@+id/tvStartTime" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="03:08" android:textStyle="bold" android:textColor="@color/dozzie_navy"/>
                <TextView android:id="@+id/tvStartDate" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="30/4/2026" android:textSize="10sp"/>
            </LinearLayout>
            <View android:layout_width="20dp" android:layout_height="1dp" android:background="#D1D5DB" android:layout_gravity="center" />
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:gravity="end"
                android:orientation="vertical"
                android:layout_height="wrap_content">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CHECK-OUT" android:textSize="10sp" />
                <TextView android:id="@+id/tvEndTime" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="04:08" android:textStyle="bold" android:textColor="@color/dozzie_navy"/>
                <TextView android:id="@+id/tvEndDate" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="30/4/2026" android:textSize="10sp"/>
            </LinearLayout>
        </LinearLayout>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">
            <TextView
                android:id="@+id/tvKey"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="#E0F2FE"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:text="CHÌA KHÓA PHÒNG: 282535"
                android:textColor="@color/dozzie_blue"
                android:textStyle="bold"
                android:textSize="12sp" />
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:gravity="end"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="TỔNG THANH TOÁN" android:textSize="10sp" />
                <TextView android:id="@+id/tvTotalPrice" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="100.000 đ" android:textColor="@color/dozzie_danger" android:textStyle="bold" android:textSize="16sp" />
            </LinearLayout>
        </RelativeLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>