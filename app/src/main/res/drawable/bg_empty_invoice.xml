<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Màu nền của khung (nên để trắng hoặc trùng màu background app) -->
    <solid android:color="@color/white" />

    <!--
        Đường viền đứt đoạn:
        - width: Độ dày viền
        - color: Màu viền (tôi dùng màu đen mờ 20% - #33000000)
        - dashWidth: Độ dài của một đoạn gạch
        - dashGap: Khoảng cách giữa các đoạn gạch
    -->
    <stroke
        android:width="1.5dp"
        android:color="#33000000"
        android:dashWidth="6dp"
        android:dashGap="6dp" />

    <!-- Bo góc cho khung giống ảnh mẫu -->
    <corners android:radius="24dp" />
</shape>